syntax on

set cc=80
set noet ci pi sts=0 sw=4 ts=4
set ruler

colorscheme desert

set guioptions=r
set mousem=popup_setpos
set mouse=a

set noswapfile

set backspace=indent,eol,start

filetype plugin on
filetype indent on

set list "Show hidden characters
set listchars=tab:»»,trail:· "What to show instead of characters
